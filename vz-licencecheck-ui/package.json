{
  "title": "ASTRA VZ-Licencecheck",
  "name": "vz-licencecheck-ui",
  "version": "2.3.0",
  "license": "All Rights Reserved",
  "organization": {
    "name": "Federal Office of Information Technology, Systems and Telecommunication FOITT",
    "url": "https://www.bit.admin.ch/"
  },
  "private": true,
  "scripts": {
    "start": "ng serve --port 4201",
    "build": "ng build",
    "watch": "ng build --watch",
    "test": "ng test --verbose=false --watch=false --coverage=false",
    "test:ci": "ng test --watch=false --run-in-band --collect-coverage",
    "start-test": "ng serve --host 0.0.0.0 --port 4201 --configuration=test",
    "lint": "ng lint",
    "prettier": "prettier --write **/{*.ts,*.html,*.scss,*.json,*.js}",
    "format": "npm run lint -- --fix && npm run prettier",
    "pregenerate:api": "rimraf src/app/core/api/generated",
    "generate:api": "HTTPS_PROXY=\"\" NODE_TLS_REJECT_UNAUTHORIZED='0' openapi-generator-cli generate --generator-key angular-client-api",
    "postgenerate:api": "./node_modules/.bin/prettier --write src/app/core/api/generated/**/{*.ts,*.html,*.scss,*.json,*.js,*.md}"
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.2",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@npmcli/package-json": "^7.0.5",
    "@oblique/oblique": "^15.1.1",
    "@popperjs/core": "^2.11.8",
    "check-image-type": "^0.1.4",
    "ngx-cookie-service": "^21.1.0",
    "rxjs": "^7.4.0",
    "tslib": "^2.7.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.3",
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "^21.2.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.34.0",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@rollup/rollup-linux-x64-gnu": "^4.48.1",
    "@schematics/angular": "^21.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "ajv": "^8.18.0",
    "babel-plugin-istanbul": "^7.0.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.1.1",
    "jest-sonar-reporter": "^2.0.0",
    "lint-staged": "^16.3.3",
    "ng-lint-staged": "^12.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-dev-server": "^5.2.3"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  },
  "lint-staged": {
    "**/*.{js,ts,md,html,json}": [
      "prettier --write"
    ],
    "**/*.ts": [
      "ng-lint-staged lint --fix --"
    ]
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.48.1"
  }
}
