{
  "title": "ASTRA VZ-Licencecheck",
  "name": "vz-licencecheck-ui",
  "version": "1.13.0",
  "license": "All Rights Reserved",
  "organization": {
    "name": "Federal Office of Information Technology, Systems and Telecommunication FOITT",
    "url": "https://www.bit.admin.ch/"
  },
  "private": true,
  "scripts": {
    "start": "ng serve --port 4201",
    "build": "ng build",
    "watch": "ng build --watch",
    "test": "ng test",
    "start-test": "ng serve --host 0.0.0.0 --port 4201 --configuration=test",
    "test:ci": "ng test --watch=false --run-in-band --force-exit --collect-coverage",
    "lint": "ng lint",
    "prettier": "prettier --write **/{*.ts,*.html,*.scss,*.json,*.js}",
    "format": "npm run lint -- --fix && npm run prettier",
    "pregenerate:api": "rimraf src/app/core/api/generated",
    "generate:api": "HTTPS_PROXY=\"\" NODE_TLS_REJECT_UNAUTHORIZED='0' openapi-generator-cli generate --generator-key angular-client-api",
    "postgenerate:api": "./node_modules/.bin/prettier --write src/app/core/api/generated/**/{*.ts,*.html,*.scss,*.json,*.js,*.md}"
  },
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^19.2.14",
    "@angular/forms": "^19.2.14",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-browser-dynamic": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@npmcli/package-json": "^5.2.1",
    "@oblique/oblique": "^13.3.2",
    "@popperjs/core": "^2.11.8",
    "check-image-type": "^0.1.4",
    "glob": "^10.4.5",
    "lru-cache": "^10.4.3",
    "ngx-cookie-service": "^19.1.2",
    "rimraf": "^5.0.10",
    "rxjs": "^7.4.0",
    "tslib": "^2.7.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^19.0.1",
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/schematics": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/build": "^19.2.15",
    "@angular/cli": "~19.2.15",
    "@angular/compiler-cli": "^19.2.14",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@openapitools/openapi-generator-cli": "2.18.4",
    "@rollup/rollup-linux-x64-gnu": "^4.48.1",
    "@schematics/angular": "^19.2.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.11",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "ajv": "^8.17.1",
    "babel-plugin-istanbul": "^6.1.1",
    "esbuild": "^0.23.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-sonar-reporter": "^2.0.0",
    "lint-staged": "^15.5.2",
    "ng-lint-staged": "12.0.4",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-dev-server": "^4.15.2"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  },
  "lint-staged": {
    "**/*.{js,ts,md,html,json}": [
      "prettier --write"
    ],
    "**/*.ts": [
      "ng-lint-staged lint --fix --"
    ]
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.48.1"
  }
}
